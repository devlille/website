---
import type { GetStaticPaths } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { marked } from "marked";
import PartnerBlock from "../components/PartnerBlock.astro";
import SocialList from "../components/SocialList.astro";
import config from "../config/config.ts";

interface Props {
    speaker: CollectionEntry<"speakers">;
}

export const getStaticPaths = (async () => {
    const speakers = await getCollection("speakers");

    return speakers.map((speaker) => ({
        params: {
            id: speaker.id,
        },
        props: {
            speaker: speaker,
        },
    }));
}) satisfies GetStaticPaths;

const { speaker } = Astro.props;

const speakerName = speaker.data.display_name ?? "Speaker";

const stripMarkdown = (text: string): string =>
    text
        .replace(/!\[[^\]]*\]\([^)]*\)/g, "")
        .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
        .replace(/[*_`~#>]+/g, "")
        .replace(/\s+/g, " ")
        .trim();

const truncate = (text: string, max = 160): string =>
    text.length > max ? text.slice(0, max - 1).trimEnd() + "…" : text;

const fallbackDescription = `Découvrez ${speakerName}${
    speaker.data.company ? ` (${speaker.data.company})` : ""
}, speaker à DevLille ${config.edition}.`;

const metaDescription = speaker.data.bio
    ? truncate(stripMarkdown(speaker.data.bio))
    : fallbackDescription;

const og = {
    ogDescription: metaDescription,
    ogUrl: "https://devlille.fr/speaker-page-" + speaker.id,
    ogImage: speaker.data.photo_url,
};

const talks = await getCollection("talks");

const selectedTalks = talks.filter((t) =>
    t.data.speakers?.find((s) => s.id === speaker.id),
);
---

<Layout title={`${speakerName}, speaker`} currSection="speakers" og={og}>
    <div class="page-body list speaker-sheet">
        <div class="h-group">
            {
                speaker.data.photo_url && (
                    <p class="s-photo">
                        <img
                            loading="lazy"
                            src={`${speaker.data.photo_url}?v=${Math.floor(Math.random() * 1000) + 1}`}
                            alt={`Photo de ${speaker.data.display_name}`}
                        />
                    </p>
                )
            }
            <h2>
                {speaker.data.display_name}{
                    speaker.data.pronouns ? ` (${speaker.data.pronouns})` : ""
                }
            </h2>
            <p>
                <span class="no-display">Entreprise: </span>
                {speaker.data.company ? speaker.data.company : ""}
            </p>
            <SocialList
                socials={speaker.data.socials}
                siteUrl={speaker.data.website}
                class="social"
            />
        </div>

        <div class="speaker">
            <Fragment
                set:html={speaker.data.bio
                    ? marked(speaker.data.bio.replaceAll("- ", "\r\n\r\n- "))
                    : ""}
            />
        </div>

        <div class="content">
            <div class="talks card">
                <h3>
                    <span lang="en">Talks</span> présentés par
                    {speaker.data.display_name}
                </h3>
                {
                    selectedTalks.map((selectedTalk) => {
                        return (
                            <ul class="talk">
                                <li>
                                    <a href={`/talk-page-${selectedTalk.id}`}>
                                        {selectedTalk.data?.title}
                                    </a>
                                </li>

                                {(!!selectedTalk.data?.link_slides ||
                                    !!selectedTalk.data?.link_replay) && (
                                    <div class="talk-links">
                                        <h4>Regardez ou re-regardez</h4>
                                        <ul>
                                            {selectedTalk.data?.link_replay && (
                                                <li>
                                                    <a href={selectedTalk.data.link_replay}>
                                                        La vidéo du talk
                                                    </a>
                                                </li>
                                            )}
                                            {selectedTalk.data?.link_slides && (
                                                <li>
                                                    <a href={selectedTalk.data.link_slides}>
                                                        Les slides du talk
                                                    </a>
                                                </li>
                                            )}
                                        </ul>
                                    </div>
                                )}

                                {/* <p>
                  <a href={`/talk-page-${selectedTalk.id}`}>
                    Page dédiée de ce talk
                  </a>
                </p> */}
                            </ul>
                        );
                    })
                }
            </div>

            <PartnerBlock partners={speaker.data.partners ?? []} className="speaker-partners" />
        </div>
    </div>
</Layout>
