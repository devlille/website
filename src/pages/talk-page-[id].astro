---
import type { GetStaticPaths } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { marked } from "marked";
import PartnerBlock from "../components/PartnerBlock.astro";
import FavoriteButton from "../components/FavoriteButton.astro";

interface Props {
    talk: CollectionEntry<"talks">;
}

export const getStaticPaths = (async () => {
    const talks = await getCollection("talks");

    return talks.map((talk) => ({
        params: {
            id: talk.id,
        },
        props: {
            talk: talk,
        },
    }));
}) satisfies GetStaticPaths;

const { talk } = Astro.props;

const og = {
    ogDescription: talk.data.title?.replaceAll('"', ""),
    ogUrl: "https://devlille.fr/talk-page-" + talk.id,
    ogImage: talk.data.speakers?.[0]?.photo_url,
};

const speakers = talk.data.speakers ?? [];

const partners = [
    ...new Map(
        speakers.flatMap((s) => s.partners ?? []).map((p) => [p.id, p]),
    ).values(),
];

function shiftHeadings(html: string): string {
    return html
        .replaceAll("<h5", "<h6").replaceAll("</h5>", "</h6>")
        .replaceAll("<h4", "<h5").replaceAll("</h4>", "</h5>")
        .replaceAll("<h3", "<h4").replaceAll("</h3>", "</h4>")
        .replaceAll("<h2", "<h3").replaceAll("</h2>", "</h3>")
        .replaceAll("<h1", "<h2").replaceAll("</h1>", "</h2>");
}
---

<Layout title={talk.data.title} currSection="talks" og={og}>
    <div class="page-body list">
        <div class="talk-sheet">
            <div class="talk-top">
                <div class="description">
                    <div class="h-group">
                        <h2>{talk.data.title}</h2>
                        <FavoriteButton talkId={talk.id} sessionId={talk.data.session_id ?? ""} />
                    </div>
                    <Fragment
                        set:html={shiftHeadings(
                            marked(talk.data.abstract?.replaceAll("- ", "\r\n\r\n- ")) as string,
                        )}
                    />
                </div>
                <div class="talk-data-block card">
                    <h3>Présenté par :</h3>
                    {
                        speakers?.map((s) => {
                            return (
                                <p class="s-photo">
                                    <img
                                        loading="lazy"
                                        width="100"
                                        height="100"
                                        src={`${s.photo_url}?v=${Math.floor(Math.random() * 1000) + 1}`}
                                        alt={`Photo de ${s.display_name}`}
                                    />
                                    <a href={`/speaker-page-${s.id}`}>
                                        {s.display_name}
                                    </a>
                                </p>
                            );
                        })
                    }
                </div>

                <PartnerBlock partners={partners} className="talk-partners" />
            </div>

            {
                (talk.data.open_feedback || talk.data.link_slides) && (
                    <div class="talk-material">
                        <div class="content">
                            {talk.data.link_slides && (
                                <div class="talk-links">
                                    <h4>Regardez ou re-regardez</h4>
                                    <ul>
                                        {talk.data.link_replay && (
                                            <li>
                                                <a href={talk.data.link_replay}>
                                                    La vidéo du talk
                                                </a>
                                            </li>
                                        )}

                                        {talk.data.link_slides && (
                                            <li>
                                                <a href={talk.data.link_slides}>
                                                    Les slides du talk
                                                </a>
                                            </li>
                                        )}
                                    </ul>
                                </div>
                            )}
                            {talk.data.open_feedback && (
                                <p class="openfb">
                                    Suite à la conférence, vous pouvez faire
                                    un retour aux conférenciers et
                                    conférencières sur
                                    <a
                                        href={talk.data.open_feedback}
                                        target="_blank"
                                    >
                                        OpenFeedback
                                    </a>
                                </p>
                            )}
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</Layout>
